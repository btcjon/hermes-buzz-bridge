# Public relay endpoint. buzz-acp accepts ws(s); use your relay's public URL.
BUZZ_RELAY_URL=wss://buzz.example.com

# Dedicated AGENT secret key only. Never use a personal or relay-owner key.
BUZZ_PRIVATE_KEY=REPLACE_WITH_DEDICATED_AGENT_SECRET

# Absolute Hermes executable path and ACP subcommand.
BUZZ_ACP_AGENT_COMMAND=/home/HERMES_USER/.local/bin/hermes
BUZZ_ACP_AGENT_ARGS=acp

# Only this Nostr identity may trigger the agent initially.
# Buzz ACP requires the owner's 64-character hex public key.
BUZZ_ACP_AGENT_OWNER=REPLACE_WITH_OWNER_HEX_PUBKEY
BUZZ_ACP_RESPOND_TO=owner-only
BUZZ_ACP_SUBSCRIBE=mentions

# Conservative runtime behavior. Self-ignore, presence, typing, and memory are
# enabled by default in the pinned Buzz version.
BUZZ_ACP_MEMORY=true
BUZZ_ACP_CONTEXT_MESSAGE_LIMIT=12
BUZZ_ACP_IDLE_TIMEOUT=900
BUZZ_ACP_MAX_TURN_DURATION=7200
RUST_LOG=info,buzz_acp=info
